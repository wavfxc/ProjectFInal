<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:Project.Converters"
             x:Class="Project.App">
    <Application.Resources>
        <ResourceDictionary>

            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:SelectionColorConverter x:Key="SelectionColorConverter" />
            <converters:SelectionBorderConverter x:Key="SelectionBorderConverter" />
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter" />
            <converters:CountGreaterThanZeroConverter x:Key="CountGreaterThanZeroConverter" />

            <Color x:Key="SteamBackground">#1b2838</Color>
            <Color x:Key="SteamPanel">#171a21</Color>
            <Color x:Key="SteamCard">#16202d</Color>
            <Color x:Key="SteamAccentBlue">#66c0f4</Color>
            <Color x:Key="SteamAccentGreen">#beee11</Color>
            <Color x:Key="SteamTextGray">#8f98a0</Color>

        </ResourceDictionary>
    </Application.Resources>
</Application>